# AI Monitor — environment variables
# Copy this file to .env and fill in your values

# Port the server listens on (default: 3005)
PORT=3005

# Pi-hole integration (leave blank to disable)
PIHOLE_HOST=127.0.0.1
PIHOLE_PASS=your_pihole_password
PIHOLE_TOTP_SECRET=your_pihole_totp_secret_if_enabled

# Discord integration (for Watchtower relay — leave blank to disable)
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_discord_channel_id
